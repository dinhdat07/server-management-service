# ============================================
# Application Settings
# ============================================
ENV=development
GRPC_PORT=50051
HTTP_PORT=8000
FRONTEND_BASE_URL=http://localhost:4200
API_BASE_URL=http://localhost:8000/api/v1

# ============================================
# Database (PostgreSQL)
# DB_URL: used for API server + daily-scheduler
# DATABASE_URL: used specifically for monitoring-worker (different format)
# ============================================
DB_URL=postgresql://postgres:postgres@localhost:5433/postgres
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/postgres

# ============================================
# Authentication & Security
# ============================================
JWT_SECRET=super-secret-key-change-in-production
JWT_ACCESS_TTL=3600
JWT_REFRESH_TTL=604800

# ============================================
# Admin & User Bootstrap (seeded on first run)
# ============================================
ADMIN_EMAIL=admin@portal.local
ADMIN_PASSWORD=Admin@123456
USER_EMAIL=user@portal.local
USER_PASSWORD=User@123456

# ============================================
# Redis (Cache & Distributed Lock)
# ============================================
REDIS_ENABLED=true
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_DIAL_TIMEOUT=5s
REDIS_READ_TIMEOUT=3s
REDIS_WRITE_TIMEOUT=3s
REDIS_POOL_SIZE=10
REDIS_MIN_IDLE_CONNS=2
REDIS_MAX_RETRIES=3

# ============================================
# Rate Limiting
# ============================================
RATE_LIMIT_ENABLED=false
RATE_LIMIT_PREFIX=portal:rl
RATE_LIMIT_DEFAULT_LIMIT=300
RATE_LIMIT_DEFAULT_BURST=300
RATE_LIMIT_DEFAULT_PERIOD=1m
RATE_LIMIT_FAIL_OPEN=true

# ============================================
# Elasticsearch (Time-Series Observation Store)
# Uses a single index: both for writing ObservationLogs (monitoring-worker)
# and reading for Uptime calculation (reporting worker)
# ============================================
ELASTICSEARCH_URL=http://localhost:9200
ELASTICSEARCH_SERVER_INDEX=sms_observation_logs

# ES Observation Logger (buffer + bulk + retry)
ES_OBSERVATION_CHANNEL_SIZE=10000
ES_OBSERVATION_BATCH_SIZE=500
ES_OBSERVATION_FLUSH_MS=2000
ES_OBSERVATION_RETRY_MAX=3
ES_OBSERVATION_RETRY_DELAY_MS=500

# ============================================
# SMTP (MailHog for dev / real SMTP for prod)
# ============================================
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=no-reply@vcs.com
SMTP_FROM_NAME=VCS Server Management
SMTP_USE_AUTH=false
SMTP_USE_TLS=false

# ============================================
# Logging (Zap + Lumberjack logrotate)
# ============================================
LOG_LEVEL=info
LOG_FORMAT=text
LOG_MAX_SIZE=10
LOG_MAX_BACKUPS=3
LOG_MAX_AGE=28
LOG_COMPRESS=true

# ============================================
# Monitoring Worker (ICMP Ping)
# ============================================
ICMP_PRIVILEGED=false
MONITORING_FAILURE_THRESHOLD=2
MONITORING_WORKER_CONCURRENCY=100
MONITORING_WORKER_PING_TIMEOUT=3s
MONITORING_WORKER_TICK_INTERVAL=30s
MONITORING_WORKER_LOCK_KEY=lock:monitoring_worker
MONITORING_WORKER_LOCK_EXPIRATION=25s

# ============================================
# Reporting Worker (Async In-Memory Pool)
# ============================================
REPORTING_WORKER_COUNT=5
REPORTING_JOB_QUEUE_SIZE=100

# ============================================
# Daily Scheduler
# ============================================
SCHEDULER_TIMEZONE=Asia/Ho_Chi_Minh
SCHEDULER_CRON_SPEC=0 0 * * *
