# Application Settings
ENV=development
HTTP_PORT=8000
GRPC_PORT=50051
API_BASE_URL=http://localhost:8000
FRONTEND_BASE_URL=http://localhost:3000

# Database
DB_URL=postgres://postgres:postgres@localhost:5433/postgres?sslmode=disable

# Authentication & Security
JWT_SECRET=super-secret-key-change-in-production
JWT_ACCESS_TTL=3600
JWT_REFRESH_TTL=604800

# Admin Bootstrap
ADMIN_EMAIL=admin@portal.local
ADMIN_PASSWORD=Admin@123456

# Redis (Caching & Rate Limiting)
REDIS_ENABLED=true
REDIS_ADDR=localhost:6379

# Kafka
KAFKA_BROKERS=localhost:9092
KAFKA_NOTIFICATION_REQUESTED_TOPIC=portal.notification.requested

# CDC & Search (Elasticsearch)
ELASTICSEARCH_URL=http://localhost:9200
KAFKA_AUDIT_TOPIC=portal.audit.logs
KAFKA_USER_TOPIC=portal.users
KAFKA_CDC_CONSUMER_GROUP=portal-cdc-indexer
ES_USER_INDEX=users
ES_AUDIT_INDEX=audit_logs

# Logging
LOG_LEVEL=info
LOG_FORMAT=text

# Monitoring Worker
ICMP_PRIVILEGED=false
MONITORING_WORKER_CONCURRENCY=100
MONITORING_WORKER_PING_TIMEOUT=3s
MONITORING_WORKER_TICK_INTERVAL=30s
MONITORING_WORKER_LOCK_KEY=lock:monitoring_worker
MONITORING_WORKER_LOCK_EXPIRATION=25s
