meta {
  name: Logout (Success)
  type: http
  seq: 4
}

post {
  url: {{baseURL}}/api/v1/auth/logout
  auth: bearer
}

auth:bearer {
  token: {{accessToken}}
}

assert {
  res.status: eq 200
  res.body.message: isString
}

script:post-response {
  bru.setVar("accessToken", "");
  bru.setVar("refreshToken", "");
}
