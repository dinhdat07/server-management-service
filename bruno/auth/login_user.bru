meta {
  name: Login - Regular User (Success)
  type: http
  seq: 2
}

post {
  url: {{baseURL}}/api/v1/auth/login
  body: json
}

body:json {
  {
    "identifier": "{{userEmail}}",
    "password": "{{userPassword}}"
  }
}

assert {
  res.status: eq 200
  res.body.access_token: exists
}

script:post-response {
  bru.setVar("userAccessToken", res.body.access_token);
  bru.setVar("userRefreshToken", res.body.refresh_token);
}
