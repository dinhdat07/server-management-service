meta {
  name: Refresh Token (Success)
  type: http
  seq: 3
}

post {
  url: {{baseURL}}/api/v1/auth/refresh
  body: json
  auth: none
}

body:json {
  {
    "refresh_token": "{{refreshToken}}"
  }
}

assert {
  res.status: eq 200
  res.body.accessToken: isString
}

script:post-response {
  if (res.body.accessToken) {
    bru.setVar("accessToken", res.body.accessToken);
  }
}
