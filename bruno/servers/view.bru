meta {
  name: View Servers (Default)
  type: http
  seq: 19
}

get {
  auth: bearer
  url: {{baseURL}}/api/v1/servers?page=1&limit=10
}

auth:bearer {
  token: {{accessToken}}
}

assert {
  res.status: eq 200
  res.body.totalCount: gte 0
  res.body.servers: isArray
}

script:post-response {
  bru.setVar("totalServers", res.body.totalCount);
}
