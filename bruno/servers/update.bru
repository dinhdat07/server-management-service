meta:
  name: Update Server (Success)
  type: http
  seq: 26

http:
  method: PUT
  url: "{{baseURL}}/api/v1/servers/{{createdServerId}}"
  body: json

body:json:
  {
    "server_name": "{{createdServerName}}-updated",
    "ipv4": "{{testServerIPv4Alt}}"
  }

assert:
  - res.status == 200
  - res.body.server.server_id == bru.getVar("createdServerId")
  - res.body.server.server_name == bru.getVar("createdServerName") + "-updated"
  - res.body.server.ipv4 == bru.getVar("testServerIPv4Alt")
