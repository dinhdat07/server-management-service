meta {
  name: Import Servers - Excel (Success)
  type: http
  seq: 33
}

post {
  url: {{baseURL}}/api/v1/servers/import
  body: multipartForm
}

body:multipart-form {
  file: @file(testdata/servers.xlsx)
}

assert {
  res.status: eq 200
  res.body.success_count: eq 3
  res.body.fail_count: eq 0
}
