meta {
  name: Import Servers - Excel (Success)
  type: http
  seq: 33
}

post {
  auth: bearer
  url: {{baseURL}}/api/v1/servers/import
  body: multipartForm
}

auth:bearer {
  token: {{accessToken}}
}

body:multipart-form {
  file_content: @file(testdata/servers.xlsx)
}

assert {
  res.status: eq 200
  res.body.successCount: eq 3
  res.body.failCount: eq 0
}
