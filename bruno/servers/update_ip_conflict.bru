meta {
  name: Update Server - IP Conflict (409)
  type: http
  seq: 28
}

put {
  auth: bearer
  url: {{baseURL}}/api/v1/servers/{{createdServerId}}
  body: json}

auth:bearer {
  token: {{accessToken}}
}

body:json {
  {
    "serverName": "{{createdServerName}}-v2",
    "ipv4": "{{testServerIPv4}}"
  }
}

assert {
  res.status: eq 409
}
