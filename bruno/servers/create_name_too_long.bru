meta {
  name: Create Server - Name > 255 chars (400)
  type: http
  seq: 17
}

post {
  url: {{baseURL}}/api/v1/servers
  body: json
}

auth:bearer {
  token: {{accessToken}}
}

body:json {
  {
    "serverName": "aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa",
    "ipv4": "10.0.0.60"
  }
}

assert {
  res.status: eq 400
}
