meta {
  name: Create Server - Duplicate IPv4 (409)
  type: http
  seq: 13
}

post {
  auth: bearer
  url: {{baseURL}}/api/v1/servers
  body: json}

auth:bearer {
  token: {{accessToken}}
}

body:json {
  {
    "serverName": "unique-name-{{$randomInt}}",
    "ipv4": "{{testServerIPv4}}"
  }
}

assert {
  res.status: eq 409
}
