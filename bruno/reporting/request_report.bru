meta {
  name: Request Uptime Report (Success)
  type: http
  seq: 38
}

post {
  url: {{baseURL}}/api/v1/servers/report
  body: json
}

body:json {
  {
    "start_date": "2026-06-01",
    "end_date": "2026-06-10",
    "target_email": "{{testReportEmail}}"
  }
}

assert {
  res.status: eq 200
  res.body.status: eq processing
  res.body.code: eq 202
  res.body.message: exists
}
