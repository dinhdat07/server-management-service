theme default

styles {
    element "Software System" {
        background #1168bd
        color #ffffff
    }
    element "External" {
        background #999999
        color #ffffff
    }
    element "Container" {
        background #438dd5
        color #ffffff
    }
    element "Component" {
        background #85bbf0
        color #000000
    }
    element "Database" {
        shape Cylinder
    }
    element "WebBrowser" {
        shape WebBrowser
    }
}
